{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2018",
		"noImplicitAny": true,
		"strictNullChecks": true,
		"noUnusedLocals": true,
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"skipLibCheck": true,
		"sourceMap": true,
		"rootDir": "./src",
		"outDir": "dist",
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"types": [
			"node",
			"jest"
		],
		"lib": [
			"es2015",
			"es2017"
		]
	},
	"include": [
		"./src/**/*"
	]
}
